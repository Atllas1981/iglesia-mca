---
import { Image } from "astro:assets";
import libroImg from "../assets/libro/LibroOmarSaiz.webp";

interface Props {
    secondaryCta?: {
        text: string;
        link: string;
    };
}

const { secondaryCta } = Astro.props;
---

<section
    class="relative bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white overflow-hidden py-20 lg:py-32"
>
    <div
        class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-5"
    >
    </div>
    <div
        class="absolute top-0 right-0 w-[800px] h-[800px] bg-indigo-500/10 rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-violet-600/10 rounded-full blur-3xl transform -translate-x-1/2 translate-y-1/2"
    >
    </div>

    <div class="container mx-auto px-6 max-w-7xl relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
            {/* Texto y Llamada a la Acción */}
            <div class="w-full lg:w-1/2 space-y-8 text-center lg:text-left">
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/20 text-indigo-300 font-medium text-sm border border-indigo-500/30 backdrop-blur-md"
                >
                    <span class="relative flex h-3 w-3">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-3 w-3 bg-indigo-500"
                        ></span>
                    </span>
                    Nuevo Lanzamiento
                </div>

                <h1
                    class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black font-montserrat leading-[1.1] tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-indigo-100 to-indigo-300"
                >
                    Descubriendo <br />
                    <span
                        class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold bg-clip-text bg-gradient-to-r from-indigo-400 to-violet-400"
                    >
                        Génesis Bereshit
                    </span>
                </h1>

                <p
                    class="text-lg sm:text-xl text-slate-300 font-inter leading-relaxed max-w-2xl mx-auto lg:mx-0"
                >
                    Adéntrate en las profundidades del texto sagrado como nunca
                    antes. Una obra única basada en las fuentes bíblicas más
                    antiguas para transformar tu comprensión del texto original
                    y su sentido espiritual y profético.
                </p>

                <div
                    class="pt-4 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
                >
                    <a
                        href="https://www.amazon.com/dp/B0DHQNWF7M"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 rounded-full shadow-[0_0_30px_rgba(79,70,229,0.4)] hover:shadow-[0_0_50px_rgba(79,70,229,0.6)] transition-all duration-300 transform hover:-translate-y-1"
                    >
                        Adquirir en Amazon
                        <svg
                            class="w-6 h-6 ml-2 group-hover:translate-x-1.5 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                        >
                    </a>
                    {
                        secondaryCta && (
                            <a
                                href={secondaryCta.link}
                                class="group inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-slate-300 bg-white/5 hover:bg-white/10 hover:text-white rounded-full border border-white/10 transition-all duration-300"
                            >
                                {secondaryCta.text}
                            </a>
                        )
                    }
                </div>

                {/* Social Proof */}
                <div
                    class="pt-8 mt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
                >
                    <div class="flex -space-x-4">
                        <img
                            class="w-10 h-10 rounded-full border-2 border-slate-900"
                            src="https://ui-avatars.com/api/?name=Reader+1&background=4F46E5&color=fff&size=100"
                            alt="Lector 1"
                        />
                        <img
                            class="w-10 h-10 rounded-full border-2 border-slate-900"
                            src="https://ui-avatars.com/api/?name=Reader+2&background=6366F1&color=fff&size=100"
                            alt="Lector 2"
                        />
                        <img
                            class="w-10 h-10 rounded-full border-2 border-slate-900"
                            src="https://ui-avatars.com/api/?name=Reader+3&background=818CF8&color=fff&size=100"
                            alt="Lector 3"
                        />
                        <img
                            class="w-10 h-10 rounded-full border-2 border-slate-900"
                            src="https://ui-avatars.com/api/?name=Reader+4&background=A5B4FC&color=fff&size=100"
                            alt="Lector 4"
                        />
                    </div>
                    <div
                        class="text-sm text-slate-400 text-center sm:text-left"
                    >
                        <span
                            class="text-white font-bold inline-flex items-center gap-1 justify-center sm:justify-start"
                        >
                            5.0
                            <svg
                                class="w-4 h-4 text-yellow-500"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path></svg
                            >
                        </span><br />
                        Cientos de lectores transformados
                    </div>
                </div>
            </div>

            {/* Imagen del Libro */}
            <div class="w-full lg:w-1/2 flex justify-center perspective-camera">
                <div
                    class="relative w-full max-w-[320px] sm:max-w-[380px] lg:max-w-[420px] group transition-all duration-700 ease-out hover:scale-[1.03] hover:rotate-y-0 text-center"
                >
                    {/* Sombra base */}
                    <div
                        class="absolute -inset-4 bg-gradient-to-tr from-indigo-500/40 to-violet-500/20 blur-3xl rounded-full opacity-60 group-hover:opacity-100 transition-opacity duration-700"
                    >
                    </div>

                    {/* Libro contenedor */}
                    <div
                        class="book-container relative transform-gpu transition-all duration-700 ease-out rounded-r-2xl rounded-l-[4px] mx-auto
            group-hover:shadow-[0_40px_80px_-15px_rgba(0,0,0,0.8)]
            before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-r before:from-white/10 before:to-transparent before:w-6 before:z-10
            shadow-[15px_15px_30px_rgba(0,0,0,0.6),-3px_0_10px_rgba(255,255,255,0.1)_inset]"
                    >
                        {/* Brillo dinamico */}
                        <div
                            class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/10 to-white/0 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 transform -translate-x-full group-hover:translate-x-full"
                        >
                        </div>

                        <Image
                            src={libroImg}
                            alt="Portada del libro Descubriendo Génesis Bereshit escrito por Omar Saiz"
                            class="w-full h-auto object-cover rounded-r-2xl rounded-l-[4px]"
                            width={800}
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .perspective-camera {
        perspective: 1200px;
    }
    .book-container {
        transform: rotateY(-18deg) rotateX(4deg);
        transform-style: preserve-3d;
    }
    .group:hover .book-container {
        transform: rotateY(-2deg) rotateX(2deg);
    }
</style>
