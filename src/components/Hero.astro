---
import { Image } from "astro:assets";
import logoMCA from "../assets/LogoMCA.webp";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="hero-wrapper">
    <!-- 1. EL "BUNKER" DEL VIDEO (Recorta cualquier error de renderizado) -->
    <div class="video-clipper">
        <video
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            class="video-object"
        >
            <source src={`${base}/videos/hero-mca.mp4`} type="video/mp4" />
        </video>
    </div>

    <!-- 2. CAPAS VISUALES (Overlays) -->
    <div class="overlay-base"></div>
    <div class="overlay-gradient"></div>

    <!-- 3. CONTENIDO INTERACTIVO -->
    <div class="content-container">
        <!-- Identidad (Parte Superior) -->
        <div class="animate-fade-in-down">
            <Image
                src={logoMCA}
                alt="Logo MCA"
                class="logo-hero"
                loading="eager"
            />
            <div class="title-wrapper">
                <h1 class="main-title">
                    Ministerio <br />
                    <span class="gold-text"> Como las Águilas </span>
                </h1>
                <p class="subtitle">Pastor Omar Saiz</p>
            </div>
        </div>

        <!-- Botones (Parte Inferior - Thumb Zone) -->
        <div class="button-wrapper animate-fade-in-up">
            <div class="flex-buttons">
                <a href="#servicios" class="btn-primary"> Visítanos Hoy </a>
                <a
                    href="https://youtube.com/@PastorOmarSaiz"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-secondary"
                >
                    YouTube
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    /* ESTRUCTURA BASE */
    .hero-wrapper {
        position: relative;
        height: 94vh; /* Un poco menos del total para evitar saltos de scroll en móvil */
        width: 100%;
        overflow: hidden;
        background-color: #001529; /* mca-blue de respaldo */
    }

    /* EL CORTE DEFINITIVO (Mata el modo espejo) */
    .video-clipper {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
    }

    .video-object {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;

        /* Optimizaciones de hardware para evitar parpadeos y reflejos en Android/iOS */
        -webkit-transform-style: preserve-3d;
        backface-visibility: hidden;
        image-rendering: -webkit-optimize-contrast;
    }

    /* CAPAS DE DISEÑO */
    .overlay-base {
        position: absolute;
        inset: 0;
        z-index: 10;
        background-color: rgba(0, 21, 41, 0.45);
        backdrop-filter: blur(1px);
    }

    .overlay-gradient {
        position: absolute;
        inset: 0;
        z-index: 10;
        background: linear-gradient(
            to bottom,
            rgba(0, 21, 41, 0.5) 0%,
            transparent 50%,
            rgba(0, 21, 41, 0.95) 100%
        );
    }

    /* CONTENEDOR DE TEXTO Y BOTONES */
    .content-container {
        position: relative;
        z-index: 20;
        height: 100%;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        text-align: center;
    }

    .logo-hero {
        height: 5rem;
        width: auto;
        margin: 0 auto 1.5rem;
        filter: drop-shadow(0 0 25px rgba(212, 175, 55, 0.3));
    }

    .main-title {
        font-family: "Montserrat", sans-serif;
        font-size: 2rem;
        font-weight: 900;
        color: white;
        text-transform: uppercase;
        line-height: 1;
        letter-spacing: -0.05em;
    }

    @media (min-width: 768px) {
        .main-title {
            font-size: 4.5rem;
        }
        .logo-hero {
            height: 7rem;
        }
    }

    .gold-text {
        color: #d4af37;
        background: linear-gradient(to right, #d4af37, #fde68a, #d4af37);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .subtitle {
        font-family: "Inter", sans-serif;
        color: #e2e8f0;
        font-size: 0.7rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        margin-top: 0.5rem;
        opacity: 0.8;
    }

    /* BOTONES */
    .button-wrapper {
        width: 100%;
        max-width: 400px;
    }

    .flex-buttons {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    @media (min-width: 640px) {
        .flex-buttons {
            flex-direction: row;
        }
    }

    .btn-primary {
        flex: 1;
        padding: 1rem;
        background-color: #d4af37;
        color: #001529;
        font-weight: 700;
        border-radius: 0.75rem;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        transition: transform 0.2s;
        box-shadow: 0 10px 15px -3px rgba(212, 175, 55, 0.3);
    }

    .btn-secondary {
        flex: 1;
        padding: 1rem;
        background-color: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(8px);
        border: 1px border rgba(255, 255, 255, 0.2);
        color: white;
        font-weight: 700;
        border-radius: 0.75rem;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        transition: all 0.2s;
    }

    .btn-primary:active,
    .btn-secondary:active {
        transform: scale(0.95);
    }

    /* ANIMACIONES */
    @keyframes fade-in-down {
        0% {
            opacity: 0;
            transform: translateY(-30px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes fade-in-up {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-down {
        animation: fade-in-down 1s ease-out forwards;
    }
    .animate-fade-in-up {
        animation: fade-in-up 1s ease-out 0.3s forwards;
        opacity: 0;
    }
</style>
