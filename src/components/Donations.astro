---
// src/components/Donations.astro
import qrImage from "../assets/QR-MCA.png";
import logoNequi from "../assets/icons/logo-nequi.webp";
import logoBancolombia from "../assets/icons/logo-bancolombia.webp";
import logoPaypal from "../assets/icons/logo-paypal.webp";
import logoBinance from "../assets/icons/logo-binance.webp";
---

<section id="donations" class="py-24 bg-slate-50 relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="font-title text-4xl font-extrabold text-slate-900 mb-4">
      Siembra en nuestro ministerio
    </h2>
    <p class="text-slate-600 mb-12 max-w-2xl mx-auto text-lg italic">
      "Cada uno debe dar según lo que haya decidido en su corazón..." - 2 Corintios 9:7
    </p>

    <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-100 max-w-2xl mx-auto p-4 sm:p-6 relative z-10">
      <div class="flex flex-col gap-2 mb-10">
        <button id="btn-colombia" class="w-full py-4 rounded-full font-bold text-lg transition-all bg-[#0d2137] text-white shadow-lg translate-y-[-2px]">
          Nacional (Colombia)
        </button>
        <button id="btn-internacional" class="w-full py-4 rounded-full font-bold text-lg transition-all bg-white text-slate-400 border-2 border-slate-100 hover:bg-slate-50">
          Internacional
        </button>
      </div>

      <div id="content-colombia" class="animate-fade-in block">
        <h3 class="text-2xl font-black text-[#0d2137] mb-2 text-balance">Donación Nacional</h3>
        <p class="text-slate-500 text-sm mb-8 px-6 font-medium">Copia el número de cuenta y transfiere desde tu app bancaria.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center px-2 pb-6">
          <div class="hidden md:flex flex-col items-center border-r border-slate-100 pr-8">
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-4 text-center">Escanear QR</p>
            <div class="p-4 bg-white rounded-2xl shadow-inner border border-slate-100">
              <img src={qrImage.src} alt="QR Pago" class="w-44 h-44 object-contain" />
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <div class="bg-[#1a5f7a] rounded-2xl overflow-hidden shadow-md border border-blue-900/20">
              <div class="py-2 px-4 text-white text-[11px] font-bold text-left opacity-90 uppercase tracking-tight">Transfiere con tu <span class="underline">Llave Bre-B</span></div>
              <div class="bg-[#f0f9ff] m-1 rounded-xl flex items-center justify-between p-1 pl-4">
                <span class="font-mono font-bold text-slate-800 text-lg">310 123 4567</span>
                <button id="copy-transfiya" class="bg-[#1a5f7a] text-white p-3 rounded-lg flex items-center gap-2 active:scale-95 transition-transform">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                  <span class="text-[10px] font-black uppercase">Copiar</span>
                </button>
              </div>
            </div>

            <button id="btn-nequi" class="w-full bg-[#700e70] hover:bg-[#5a0b5a] text-white rounded-full py-4 px-6 flex items-center shadow-lg active:scale-95 transition-all">
              <div class="w-12 h-11 bg-white rounded-full flex items-center justify-center mr-4 p-1.5 shadow-sm shrink-0">
                <img src={logoNequi.src} alt="Nequi" class="w-full h-full object-contain" />
              </div>
              <div class="text-left">
                <p class="font-bold text-lg leading-none">Dona con Nequi</p>
                <p class="text-[10px] opacity-70 uppercase font-bold mt-1 tracking-wider">(Abre la app)</p>
              </div>
            </button>

            <button id="btn-bancolombia" class="w-full bg-[#fdda24] hover:bg-[#eecb10] text-slate-900 rounded-full py-4 px-6 flex items-center shadow-lg active:scale-95 transition-all">
              <div class="w-12 h-12 rounded-full flex items-center justify-center mr-4 p-2 shrink-0 shadow-sm">
                <img src={logoBancolombia.src} alt="Bancolombia" class="w-full h-full object-contain" />
              </div>
              <div class="text-left">
                <p class="font-bold text-lg leading-none">Dona con Bancolombia</p>
                <p class="text-[10px] opacity-60 uppercase font-bold mt-1 tracking-wider">(Copia cuenta)</p>
              </div>
            </button>
          </div>
        </div>
      </div>
      
      <div id="content-internacional" class="hidden animate-fade-in">
        <h3 class="text-2xl font-black text-[#0d2137] mb-2">Otras Opciones</h3>
        <div class="flex justify-center -space-x-4 my-8">
            <div class="w-20 h-20 bg-white rounded-full border-4 border-white shadow-xl flex items-center justify-center overflow-hidden z-10"><img src={logoPaypal.src} alt="PayPal" class="w-full h-full object-cover" /></div>
            <div class="w-20 h-20 bg-[#1e2329] rounded-full border-4 border-white shadow-xl flex items-center justify-center overflow-hidden"><img src={logoBinance.src} alt="Binance" class="w-full h-full object-cover" /></div>
        </div>
        <div class="flex flex-col gap-4 max-w-md mx-auto pb-6">
          <button id="btn-paypal" class="w-full bg-[#0070ba] hover:bg-[#005ea6] text-white rounded-full py-4 px-6 flex items-center shadow-lg active:scale-95 transition-all">
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center mr-4 p-0 shrink-0 overflow-hidden shadow-sm"><img src={logoPaypal.src} alt="PayPal Icon" class="w-full h-full object-cover scale-110" /></div>
            <p class="font-bold text-lg flex-1 text-left">Donar con PayPal</p>
          </button>
          <button id="btn-binance" class="w-full bg-[#1e2329] hover:bg-[#2b3139] text-white rounded-full py-4 px-6 flex items-center shadow-lg active:scale-95 transition-all">
            <div class="w-12 h-12 bg-[#f0b90b] rounded-full flex items-center justify-center mr-4 p-0 shrink-0 overflow-hidden shadow-sm"><img src={logoBinance.src} alt="Binance Icon" class="w-full h-full object-cover scale-110" /></div>
            <p class="font-bold text-lg flex-1 text-left">Dona con Binance Pay</p>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="modal-bancolombia" class="fixed inset-0 z-[100] grid place-items-center bg-slate-900/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 px-6">
  <div class="bg-white rounded-[2.5rem] p-8 w-full max-w-sm shadow-2xl transform scale-95 transition-transform duration-300 relative border border-slate-100">
    
    <button id="close-modal" class="absolute top-6 right-6 text-slate-300 hover:text-slate-600 transition p-1 z-20">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    
    <div class="text-center">
      <div class="flex justify-center mb-6 relative z-10">
        <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-xl border-2 border-slate-50 p-4 overflow-hidden">
          <img 
            src={logoBancolombia.src} 
            alt="Bancolombia" 
            class="w-full h-full object-contain transform scale-150 origin-center" 
          />
        </div>
      </div>
      
      <h3 class="text-3xl font-black text-slate-900 mb-2 leading-tight">¡Número de Cuenta Copiado!</h3>
      
      <div class="mt-6 mb-2">
          <div class="bg-slate-50 border-2 border-slate-100 rounded-2xl px-5 py-4 inline-block shadow-inner">
              <p id="modal-acc-number" class="text-3xl font-mono font-black tracking-wider text-slate-900">79595061933</p>
          </div>
          <p class="text-sm font-bold text-slate-500 mt-2">(Cuenta de Ahorros)</p>
      </div>
      
      <p class="text-slate-600 text-sm leading-relaxed mb-8 font-medium">
        Por seguridad, abre tu App Bancolombia <span class="font-bold">manualmente</span> y pega el número.
      </p>
      
      <button id="accept-modal" class="bg-[#0d2137] text-white text-lg font-black w-full py-5 rounded-2xl shadow-xl hover:shadow-2xl transition transform active:scale-95 uppercase tracking-wide">
        Aceptar
      </button>
    </div>
  </div>
</div>

  <div id="toast-msg" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-8 py-3 rounded-full text-sm font-bold shadow-2xl opacity-0 transition-all pointer-events-none z-50 transform translate-y-4">
    ¡Copiado con éxito!
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const CONFIG = {
    account: "79595061933",
    transfiya: "3101234567",
    paypalUrl: "https://www.paypal.com/paypalme/omarsaiz",
    binanceId: "123456789",
  };

  const modal = document.getElementById("modal-bancolombia");
  const modalContent = modal?.querySelector('div');
  const toast = document.getElementById("toast-msg");

  function showToast(msg: string) {
    if (!toast) return;
    toast.innerText = msg;
    toast.classList.remove("opacity-0", "translate-y-4");
    setTimeout(() => toast.classList.add("opacity-0", "translate-y-4"), 3000);
  }

  function toggleModal(show: boolean) {
    if (!modal || !modalContent) return;
    if (show) {
      modal.classList.remove("opacity-0", "pointer-events-none");
      modalContent.classList.replace("scale-95", "scale-100");
    } else {
      modal.classList.add("opacity-0", "pointer-events-none");
      modalContent.classList.replace("scale-100", "scale-95");
    }
  }

  // EVENTO NEQUI
  document.getElementById("btn-nequi")?.addEventListener("click", () => {
    navigator.clipboard.writeText(CONFIG.account);
    showToast("Cuenta copiada. Abriendo Nequi...");
    setTimeout(() => { window.location.href = "nequi://"; }, 800);
  });

  // EVENTO BANCOLOMBIA (Ahora abre el modal en vez de alert)
  document.getElementById("btn-bancolombia")?.addEventListener("click", () => {
    navigator.clipboard.writeText(CONFIG.account);
    toggleModal(true);
    showToast("¡Cuenta copiada!");
  });

  // Cerrar Modal
  document.getElementById("close-modal")?.addEventListener("click", () => toggleModal(false));
  document.getElementById("accept-modal")?.addEventListener("click", () => toggleModal(false));
  modal?.addEventListener("click", (e) => { if(e.target === modal) toggleModal(false); });

  // EVENTOS RESTANTES
  document.getElementById("copy-transfiya")?.addEventListener("click", () => {
    navigator.clipboard.writeText(CONFIG.transfiya);
    showToast("Llave Bre-B copiada");
  });

  document.getElementById("btn-paypal")?.addEventListener("click", () => {
    window.open(CONFIG.paypalUrl, "_blank");
  });

  document.getElementById("btn-binance")?.addEventListener("click", () => {
    navigator.clipboard.writeText(CONFIG.binanceId);
    showToast("ID de Binance copiado");
  });

  // LOGICA DE TABS
  const bCol = document.getElementById("btn-colombia");
  const bInt = document.getElementById("btn-internacional");
  const cCol = document.getElementById("content-colombia");
  const cInt = document.getElementById("content-internacional");

  function toggleTabs(isInt: boolean) {
    if (isInt) {
      bInt?.classList.add("bg-[#0d2137]", "text-white", "shadow-lg", "translate-y-[-2px]");
      bCol?.classList.add("bg-white", "text-slate-400", "border-2");
      bCol?.classList.remove("bg-[#0d2137]", "text-white", "shadow-lg", "translate-y-[-2px]");
      cCol?.classList.add("hidden");
      cInt?.classList.remove("hidden");
    } else {
      bCol?.classList.add("bg-[#0d2137]", "text-white", "shadow-lg", "translate-y-[-2px]");
      bInt?.classList.add("bg-white", "text-slate-400", "border-2");
      bInt?.classList.remove("bg-[#0d2137]", "text-white", "shadow-lg", "translate-y-[-2px]");
      cInt?.classList.add("hidden");
      cCol?.classList.remove("hidden");
    }
  }

  bCol?.addEventListener("click", () => toggleTabs(false));
  bInt?.addEventListener("click", () => toggleTabs(true));
</script>