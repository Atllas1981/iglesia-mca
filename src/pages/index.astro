---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import LiveCounter from "../components/LiveCounter.jsx";
import BookHero from "../components/BookHero.astro";
import Donations from "../components/Donations.astro";
import Location from "../components/Location.astro";
import CarteleraSlider from "../components/CarteleraSlider.astro";

// Importamos el componente de optimización de imágenes de Astro
import { Image } from "astro:assets";

const slidesCartelera = [
    { imageUrl: "https://placehold.co/1600x900/334155/ffffff?text=1", title: "Evento Programado 1", url: "#" },
    { imageUrl: "https://placehold.co/1600x900/475569/ffffff?text=2", title: "Conferencia Magistral 2", url: "#" },
    { imageUrl: "https://placehold.co/1600x900/64748b/ffffff?text=3", title: "Taller Práctico 3", url: "#" },
    { imageUrl: "https://placehold.co/1600x900/94a3b8/ffffff?text=4", title: "Sesión Especial 4", url: "#" },
    { imageUrl: "https://placehold.co/1600x900/cbd5e1/1e293b?text=5", title: "Encuentro Presencial 5", url: "#" },
];

---

<Layout>
    <main>
        <Hero />

        <div class="relative z-50 -mt-20">
            <LiveCounter client:load />
        </div>

        <!-- Integración del nuevo componente de Cartelera  -->
        <CarteleraSlider title="Próximos Eventos" slides={slidesCartelera} />
        <div class="pt-8 relative z-10">
            <Location />
            <Donations />
        </div>

        <div class="relative z-10 mt-12 mb-0">
            <BookHero
                secondaryCta={{
                    text: "Ver página del libro",
                    link: `${import.meta.env.BASE_URL}/libro`,
                }}
            />
        </div>
    </main>
</Layout>
