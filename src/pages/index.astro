---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import LiveCounter from "../components/LiveCounter.jsx";
import Donations from "../components/Donations.astro";
import Location from "../components/Location.astro";

// Importamos el componente de optimización de imágenes de Astro
import { Image } from 'astro:assets';
// Importamos el logo desde la carpeta de activos para que Astro gestione la ruta
import logoMCA from '../assets/LogoMCA.webp';
---

<Layout>
    <main>
        <Hero />

        <div class="relative z-50 -mt-20">
            <LiveCounter client:load />
        </div>

        <div class="pt-8 relative z-10">
            <Location />
            <Donations />
        </div>
    </main>

    <footer class="bg-slate-900 text-slate-400 py-12 text-center">
        <div class="max-w-4xl mx-auto px-6">
            <Image
                src={logoMCA}
                alt="MCA Logo"
                class="h-12 w-auto mx-auto mb-6 opacity-75 grayscale hover:grayscale-0 transition-all duration-300"
            />
            <p class="mb-4 text-sm max-w-md mx-auto">
                Ministerio Como las Águilas. Extendiendo el reino de Dios y
                transformando vidas en Floridablanca y el mundo.
            </p>
            <div class="h-px w-24 bg-slate-800 mx-auto mb-6"></div>
            <p class="text-xs">
                &copy; {new Date().getFullYear()} Iglesia MCA Floridablanca. Todos
                los derechos reservados.
            </p>
        </div>
    </footer>
</Layout>