---
import Layout from "../../layouts/Layout.astro";
import CarteleraManager from "../../components/CarteleraManager";
import { isAuthorized } from "../../lib/auth";

export const prerender = false;

const authenticated = isAuthorized(Astro.request);
---

<Layout title="Administración de Cartelera - MCA">
  <div class="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans selection:bg-indigo-500/30">
    {/* Navbar / Header */}
    <header class="border-b border-slate-900 bg-slate-950/80 sticky top-0 z-40 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-indigo-500 font-black text-2xl tracking-tighter uppercase group-hover:text-indigo-400 transition-colors">MCA</span>
          <span class="text-slate-500">|</span>
          <span class="text-slate-300 font-bold text-sm tracking-wide uppercase">Dashboard</span>
        </a>
        
        {authenticated && (
          <button 
            id="logoutBtn"
            class="px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-white border border-slate-800 hover:border-slate-700 bg-slate-950 rounded-xl transition-all duration-300 cursor-pointer"
          >
            Cerrar Sesión
          </button>
        )}
      </div>
    </header>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col">
      {authenticated ? (
        <CarteleraManager client:only="react" />
      ) : (
        <div class="flex-grow flex items-center justify-center py-10">
          <div class="w-full max-w-md p-8 sm:p-10 rounded-[2.5rem] bg-slate-900/40 border border-slate-900/60 shadow-2xl backdrop-blur-xl space-y-8 animate-fadeIn">
            <div class="text-center space-y-2">
              <div class="inline-flex p-3.5 bg-indigo-500/10 text-indigo-400 rounded-2xl border border-indigo-500/20 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <h1 class="text-2xl font-black text-white tracking-tight uppercase">Panel de Control</h1>
              <p class="text-xs text-slate-400 font-medium">Ingresa la contraseña administrativa para continuar</p>
            </div>

            <form id="loginForm" class="space-y-6">
              <div class="space-y-2">
                <label for="password" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                  Contraseña
                </label>
                <input
                  type="password"
                  id="password"
                  required
                  placeholder="••••••••"
                  class="w-full bg-slate-950/80 border border-slate-900 focus:border-indigo-500 rounded-2xl px-5 py-4 text-sm text-slate-200 placeholder-slate-700 focus:outline-none transition-colors duration-300"
                />
              </div>

              <div id="loginError" class="hidden text-xs font-semibold text-red-400 bg-red-950/40 border border-red-900/40 p-3.5 rounded-2xl animate-shake">
                {/* Mensaje de error dinámico */}
              </div>

              <button
                type="submit"
                id="submitBtn"
                class="w-full flex items-center justify-center gap-2 px-6 py-4 bg-gradient-to-r from-indigo-500 to-purple-600 hover:shadow-indigo-500/20 hover:scale-[1.01] hover:shadow-lg text-white text-sm font-bold uppercase tracking-wider rounded-2xl transition-all duration-300 cursor-pointer"
              >
                Ingresar
              </button>
            </form>
          </div>
        </div>
      )}
    </main>
  </div>
</Layout>

<script>
  // Script para manejar el Login en el cliente
  const loginForm = document.getElementById('loginForm') as HTMLFormElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const loginError = document.getElementById('loginError') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  if (loginForm) {
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      loginError.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Verificando...';

      try {
        const res = await fetch('/api/cartelera/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: passwordInput.value }),
        });

        if (res.ok) {
          // Recargar la página para renderizar el Dashboard
          window.location.reload();
        } else {
          const data = await res.json();
          loginError.textContent = data.error || 'Error al autenticar';
          loginError.classList.remove('hidden');
        }
      } catch (err: any) {
        loginError.textContent = 'Error de conexión';
        loginError.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Ingresar';
      }
    });
  }

  // Script para manejar el Logout en el cliente
  const logoutBtn = document.getElementById('logoutBtn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
      // Borrar la cookie de sesión configurando su fecha de expiración en el pasado
      document.cookie = 'admin_session=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;';
      window.location.reload();
    });
  }
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }
  .animate-shake {
    animation: shake 0.2s ease-in-out 0s 2;
  }
</style>
